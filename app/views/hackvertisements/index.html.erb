<% content_for :title, "Hackvertisements" %>

<style>
#admin-panel-item {
  text-decoration: underline;
}
.admin-hackvertisement-entry {  
  margin-bottom: 10px;
  border: 1px solid black;
  padding: 5px;
  width: fit-content;
  margin-left:auto;
  margin-right:auto;
}
.admin-hackvertisement-image {
  height: 4em;
}
</style>

<div class="container">
  <div>
    <h1 style="margin-bottom:0">admin panel :o</h1>
    <p style="margin-top:0">If you are not me, iris, seeing this page, something has gone seriously wrong or you have hacked my server. Either way, DM me !!</p>

    <div id="hackvertisements">
      <% Hackvertisement.all.reverse.each do |hackvertisement| %>
        <div class="admin-hackvertisement-entry">
          <%= render hackvertisement %>
          <%= link_to "Show this hackvertisement", hackvertisement %>
        </div>
      <% end %>
    </div>
  </div>
</div>